PORT=3000
GO_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization
CORS_MAX_AGE=86400
RATE_LIMIT_MAX=100

###> doctrine/doctrine-bundle ###
POSTGRES_VERSION=16
POSTGRES_DB=db
POSTGRES_USER=random
POSTGRES_PASSWORD=random
POSTGRES_NAME=database
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_NAME}:5432/${POSTGRES_DB}?sslmode=disable
###< doctrine/doctrine-bundle ###

###> ngrok/ngrok ###
NGROK_AUTHTOKEN=
###< ngrok/ngrok ###

###> clerk/clerk-go ###
CLERK_WEBHOOK_SECRET=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API=
###< clerk/clerk-go ###

###> s3 ###
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_INTERNAL_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_THUMBNAIL_BUCKET=thumbnails
STORAGE_USE_PATH_STYLE=true
MINIO_WEBHOOK_SECRET=
###< s3 ###

###> rabbitmq/rabbitmq ###
RABBITMQ_DEFAULT_USER=user
RABBITMQ_DEFAULT_PASS=password
RABBITMQ_URL=amqp://user:password@rabbitmq:5672/
RABBITMQ_SECRET_KEY=
###< rabbitmq/rabbitmq ###

###> worker/worker ###
ANALYZE_REQUEST_QUEUE_NAME=analyze.request
METADATA_ANALYZE_QUEUE_NAME=metadata.analyze
METADATA_DONE_QUEUE_NAME=metadata.done
METADATA_FAILED_QUEUE_NAME=metadata.failed
HEURISTICS_ANALYZE_QUEUE_NAME=heuristics.analyze
HEURISTICS_DONE_QUEUE_NAME=heuristics.done
HEURISTICS_FAILED_QUEUE_NAME=heuristics.failed
AI_MODEL_ANALYZE_QUEUE_NAME=ai_model.analyze
AI_MODEL_DONE_QUEUE_NAME=ai_model.done
AI_MODEL_FAILED_QUEUE_NAME=ai_model.failed
EXCHANGE_NAME=exchange.events
###< worker/worker ###
